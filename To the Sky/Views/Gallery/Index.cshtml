@model List<To_the_Sky.Models.AircraftModel>

@{
	ViewData["Title"] = "Gallery";
	var aircrafts = Model ?? new List<To_the_Sky.Models.AircraftModel>();
	var countries = aircrafts.Select(a => a.Country).Distinct().OrderBy(country => country).ToList();
}
<body class="background-image">
<h1 class="mb-4">Aircraft Gallery</h1>

<!-- Dropdown --> 
<div id="dropdown" class="dropdown">
	<button id="dropdownButton" class="btn btn-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
		All Countries
	</button>
	<ul id="countryList" class="dropdown-menu">
		<li><button type="button" class="dropdown-item" data-country="">All Countries</button></li>
		@foreach (var country in countries)
		{
			<li><button type="button" class="dropdown-item" data-country="@country">@country</button></li>
		}
	</ul>
</div>

<p id="galleryEmptyState" class="alert alert-info d-none mt-3 mb-4">
	No aircraft match the selected country.
</p>


<!-- Aircraft gallery --> 
@if (!aircrafts.Any())
{
	<p>No aircraft available right now.</p>
}
else
{
	<div class="gallery-grid">
		@foreach (var aircraft in aircrafts)
		{
			<article class="aircraft-card" data-country="@aircraft.Country">
				<div class="aircraft-card__image">
					<img src="@aircraft.ImageUrl" alt="@aircraft.Name">
				</div>
				<div class="aircraft-card__body">
					<h5 class="aircraft-card__title">@aircraft.Name</h5>
					<p class="aircraft-card__text">@aircraft.Description</p>
					<dl class="aircraft-card__meta">
						<div><dt>Manufacturer</dt><dd>@aircraft.Manufacturer</dd></div>
						<div><dt>Category</dt><dd>@aircraft.Category</dd></div>
						<div><dt>Country</dt><dd>@aircraft.Country</dd></div>
						<div><dt>First Flight</dt><dd>@aircraft.FirstFlight</dd></div>
						<div><dt>Last Flight</dt><dd>@aircraft.LastFlight</dd></div>
					</dl>
					<a class="aircraft-card__link" asp-controller="Aircraft" asp-action="Detailed" asp-route-id="@aircraft.Id">Read More</a>
				</div>
			</article>
		}
	</div>
}
</body>