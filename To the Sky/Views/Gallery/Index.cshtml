@model List<To_the_Sky.Models.AircraftModel>

@{
	ViewData["Title"] = "Gallery";
}

<h1 class="mb-4">Aircraft Gallery (Temporary Data)</h1>

@if (Model == null || !Model.Any())
{
	<p>No aircraft available right now.</p>
}
else
{
	<div class="gallery-grid">
		@foreach (var aircraft in Model)
		{
			<article class="aircraft-card">
				<div class="aircraft-card__image">
					<img src="@aircraft.ImageUrl" alt="@aircraft.Name">
				</div>
				<div class="aircraft-card__body">
					<h5 class="aircraft-card__title">@aircraft.Name</h5>
					<p class="aircraft-card__text">@aircraft.Description</p>
					<dl class="aircraft-card__meta">
						<div><dt>Manufacturer</dt><dd>@aircraft.Manufacturer</dd></div>
						<div><dt>Category</dt><dd>@aircraft.Category</dd></div>
						<div><dt>Country</dt><dd>@aircraft.Country</dd></div>
						<div><dt>First Flight</dt><dd>@aircraft.FirstFlight</dd></div>
						<div><dt>Last Flight</dt><dd>@aircraft.LastFlight</dd></div>
					</dl>
					<a class="aircraft-card__link" asp-controller="Aircraft" asp-action="Detailed" asp-route-id="@aircraft.Id">Read More</a>
				</div>
			</article>
		}
	</div>
}